{
  "name": "@asymmetric-legal/vision-worker",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "dev": "node --enable-source-maps --loader ts-node/esm src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "echo \"No lint configured for vision-worker yet\"",
    "format": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asymmetric-legal/types": "workspace:*",
    "@asymmetric-legal/utils": "workspace:*"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
